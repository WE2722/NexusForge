# LLM Providers (Required)
GOOGLE_API_KEY=your_google_ai_studio_key_here
GROQ_API_KEY=your_groq_console_key_here
MISTRAL_API_KEY=your_mistral_console_key_here
OPENROUTER_API_KEY=your_openrouter_key_here_optional

# Database (Required)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/nexusforge
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_key_here

# Cache (Required)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Auth (Required)
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# App Config
DEBUG=true
LOG_LEVEL=INFO
DEFAULT_LLM_PROVIDER=google
MAX_TOKENS_PER_PROJECT=50000